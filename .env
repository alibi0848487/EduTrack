# Edutrack — пример переменных окружения
# Скопируй в .env и заполни своими значениями

DATABASE_URL=postgresql://edutrack:password@localhost:5432/edutrack_db
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Начальный баланс SkillCoins при регистрации
INITIAL_SKILL_COINS=100.0

# Награда за создание урока
LESSON_CREATE_REWARD=20.0
